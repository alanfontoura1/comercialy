# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=comercialy
POSTGRES_USER=comercialy_user
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://comercialy_user:CHANGE_ME@localhost:5432/comercialy

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_min_32_chars
JWT_EXPIRES_IN=7d

# ─── Google Gemini (IA gratuita) ─────────────────────────────────────────────
# Pegue grátis em: aistudio.google.com → Get API Key
GEMINI_API_KEY=AIza...

# ─── Evolution API (WhatsApp) ────────────────────────────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=CHANGE_ME
WEBHOOK_SECRET=CHANGE_ME

# ─── Google Calendar ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=http://localhost:3001/api/integrations/google/callback

# ─── URLs ────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:3001/api
VITE_WS_URL=ws://localhost:3001
