NODE_ENV=production
PORT=3001

# PostgreSQL
DATABASE_URL=postgresql://USUARIO:SENHA@HOST:5432/comercialy

# Segurança
JWT_SECRET=troque_por_string_aleatoria_longa_aqui
JWT_EXPIRES_IN=7d
WEBHOOK_SECRET=troque_por_string_aleatoria_aqui

# IA (use pelo menos um)
AI_PROVIDER=groq
GROQ_API_KEY=sua_chave_groq_aqui
GEMINI_API_KEY=sua_chave_gemini_aqui

# Google Calendar (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://SEU_DOMINIO/api/google/callback
GOOGLE_CALENDAR_ID=primary

# URLs
FRONTEND_URL=https://SEU_FRONTEND.vercel.app
